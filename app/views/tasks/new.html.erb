<div class="max-w-2xl mx-auto px-4 py-12 font-sans">
  <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
    
    <div class="mb-8">
      <h1 class="text-2xl font-extrabold text-gray-900">New Task</h1>
      <p class="text-sm text-gray-500 mt-1">Adding to project: <strong><%= @project.name %></strong></p>
    </div>

    <%= form_with model: [@project, @task], class: "space-y-6" do |form| %>
      
      <div>
        <%= form.label :title, class: "block text-sm font-semibold text-gray-700 mb-1" %>
        <%= form.text_field :title, required: true, autofocus: true, class: "w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors", placeholder: "e.g., Design the new logo" %>
      </div>

      <div class="grid grid-cols-2 gap-6">
        <div>
          <%= form.label :status, class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= form.select :status, Task.statuses.keys.map { |s| [s.titleize, s] }, {}, class: "w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
        </div>

        <div>
          <%= form.label :due_date, class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= form.date_field :due_date, class: "w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
        </div>
      </div>

      <div class="pt-6 border-t border-gray-100 flex justify-end gap-3">
        <%= link_to "Cancel", @project, class: "px-5 py-2 text-sm font-semibold text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors" %>
        <%= form.submit "Create Task", class: "px-5 py-2 text-sm font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700 cursor-pointer transition-colors" %>
      </div>

    <% end %>
  </div>
</div>