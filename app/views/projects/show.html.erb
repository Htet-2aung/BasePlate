<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 font-sans">
  
  <div class="flex flex-col md:flex-row md:items-center justify-between mb-8">
    <div>
      <div class="flex items-center gap-2 text-sm text-gray-500 mb-2">
        <%= link_to "Projects", projects_path, class: "hover:text-gray-900 transition-colors" %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        <span class="text-gray-900 font-medium"><%= @project.name %></span>
      </div>
      <h1 class="text-3xl font-extrabold text-gray-900"><%= @project.name %></h1>
    </div>
    
    <div class="mt-4 md:mt-0 flex gap-3">
      <%= link_to "Edit Details", edit_project_path(@project), class: "px-4 py-2 bg-white border border-gray-300 rounded-lg text-sm font-semibold text-gray-700 hover:bg-gray-50 shadow-sm transition-all" %>
      <%= link_to "+ New Task", new_project_task_path(@project), class: "px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-semibold hover:bg-blue-700 shadow-sm transition-all" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
      <h3 class="text-sm font-semibold text-gray-500 mb-1 uppercase tracking-wider">Total Tasks</h3>
      <div class="text-3xl font-bold text-gray-900"><%= @project.tasks.count %></div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
       <h3 class="text-sm font-semibold text-gray-500 mb-1 uppercase tracking-wider">Completed</h3>
       <div class="text-3xl font-bold text-green-600"><%= @project.tasks.done.count %></div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
       <h3 class="text-sm font-semibold text-gray-500 mb-1 uppercase tracking-wider">Team Members</h3>
       <div class="flex -space-x-2 overflow-hidden mt-3">
         <div class="inline-block h-10 w-10 rounded-full ring-2 ring-white bg-gradient-to-tr from-purple-500 to-indigo-500 text-white flex items-center justify-center font-bold text-sm shadow-sm">ME</div>
       </div>
    </div>
  </div>

  <div class="border-b border-gray-200 mb-8">
    <nav class="-mb-px flex space-x-8">
      <%= link_to "Kanban Board", project_path(@project), class: "whitespace-nowrap pb-4 px-1 border-b-2 font-medium text-sm #{params[:tab] != 'calendar' ? 'border-blue-600 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700'}" %>
      
      <%= link_to project_path(@project, tab: 'calendar'), class: "whitespace-nowrap pb-4 px-1 border-b-2 font-medium text-sm flex items-center gap-2 #{params[:tab] == 'calendar' ? 'border-blue-600 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700'}" do %>
        Calendar
      <% end %>
    </nav>
  </div>

  <% if params[:tab] == 'calendar' %>
    
    <div class="bg-white p-6 rounded-xl border border-gray-200 shadow-sm overflow-x-auto">
      <%= month_calendar(events: @project.tasks, attribute: :due_date) do |date, tasks| %>
        <div class="text-right text-sm text-gray-500 mb-2 font-medium"><%= date.day %></div>
        <div class="space-y-1">
          <% tasks.each do |task| %>
            <div class="text-xs p-1.5 rounded bg-blue-50 border border-blue-100 text-blue-800 font-semibold truncate" title="<%= task.title %>">
              <%= task.title %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

  <% else %>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 flex flex-col h-full">
        <h3 class="font-bold text-gray-700 mb-3 flex justify-between items-center">
          To Do <span class="bg-gray-200 text-gray-600 py-0.5 px-2 rounded-full text-xs"><%= @project.tasks.todo.count %></span>
        </h3>
        <div class="space-y-3 flex-grow">
          <% @project.tasks.todo.each do |task| %>
            <div class="bg-white p-3 rounded-lg shadow-sm border border-gray-200 hover:border-blue-300 transition-all">
              <h4 class="font-semibold text-gray-900 text-sm"><%= task.title %></h4>
              <% if task.due_date %>
                <div class="text-xs text-gray-500 mt-2 flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                  <%= task.due_date.strftime("%b %d") %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="bg-blue-50 rounded-xl p-4 border border-blue-100 flex flex-col h-full">
        <h3 class="font-bold text-blue-800 mb-3 flex justify-between items-center">
          In Progress <span class="bg-blue-200 text-blue-800 py-0.5 px-2 rounded-full text-xs"><%= @project.tasks.in_progress.count %></span>
        </h3>
        <div class="space-y-3 flex-grow">
          <% @project.tasks.in_progress.each do |task| %>
            <div class="bg-white p-3 rounded-lg shadow-sm border border-blue-200 hover:border-blue-400 transition-all">
              <h4 class="font-semibold text-gray-900 text-sm"><%= task.title %></h4>
            </div>
          <% end %>
        </div>
      </div>

      <div class="bg-green-50 rounded-xl p-4 border border-green-100 flex flex-col h-full">
        <h3 class="font-bold text-green-800 mb-3 flex justify-between items-center">
          Done <span class="bg-green-200 text-green-800 py-0.5 px-2 rounded-full text-xs"><%= @project.tasks.done.count %></span>
        </h3>
        <div class="space-y-3 flex-grow">
          <% @project.tasks.done.each do |task| %>
            <div class="bg-white p-3 rounded-lg shadow-sm border border-green-200 opacity-60">
              <h4 class="font-semibold text-gray-500 text-sm line-through"><%= task.title %></h4>
            </div>
          <% end %>
        </div>
      </div>
    </div>

  <% end %>
</div>