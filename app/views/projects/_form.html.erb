<%= form_with(model: project, class: "space-y-6") do |form| %>
  
  <%# Error Handling UI %>
  <% if project.errors.any? %>
    <div class="bg-red-50 text-red-700 p-4 rounded-lg border border-red-200 mb-6">
      <h2 class="font-bold text-sm mb-2"><%= pluralize(project.errors.count, "error") %> prohibited this from being saved:</h2>
      <ul class="list-disc list-inside text-sm ml-4">
        <% project.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Project Name Field %>
  <div>
    <%= form.label :name, class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= form.text_field :name, class: "w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors", placeholder: "e.g., Q3 Marketing Campaign" %>
  </div>

  <%# Project Description Field %>
  <div>
    <%= form.label :description, class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= form.text_area :description, rows: 4, class: "w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors", placeholder: "What is the goal of this project?" %>
  </div>

  <%# Submit Button %>
  <div class="flex justify-end pt-2">
    <%= form.submit class: "px-6 py-2 bg-black text-white font-semibold rounded-lg hover:bg-gray-800 cursor-pointer transition-colors shadow-sm" %>
  </div>
<% end %>