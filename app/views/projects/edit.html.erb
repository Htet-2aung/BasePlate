<% content_for :title, "Editing Project" %>

<div class="max-w-2xl mx-auto px-4 py-12 font-sans">
  <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
    
    <div class="mb-8">
      <h1 class="text-2xl font-extrabold text-gray-900">Edit Project Details</h1>
      <p class="text-sm text-gray-500 mt-1">Update your workspace name and description.</p>
    </div>

    <%= render "form", project: @project %>

    <div class="mt-8 pt-6 border-t border-gray-100 flex items-center justify-between text-sm">
      <%= link_to "← Back to Projects", projects_path, class: "font-semibold text-gray-500 hover:text-gray-900 transition-colors" %>
      <%= link_to "View Dashboard →", @project, class: "font-semibold text-blue-600 hover:text-blue-800 transition-colors" %>
    </div>

  </div>
</div>